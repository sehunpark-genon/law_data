      "content": "[별지 제5호서식]\n┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\n┃기술신탁관리업 허가증 관리대장                                  ┃\n┠──┬───┬─────┬───┬───┬───┬───────┨\n┃일련│허가일│법인 명칭 │대표자│소재지│수령인│비  고        ┃\n┃번호│      │          │      │      │      │(발급, 재발급)┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┠──┼───┼─────┼───┼───┼───┼───────┨\n┃    │      │          │      │      │      │              ┃\n┗━━┷━━━┷━━━━━┷━━━┷━━━┷━━━┷━━━━━━━┛\n210㎜×297㎜[일반용지 60g/㎡(재활용품)]",
