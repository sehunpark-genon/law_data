      "content": "■ 보건범죄단속에관한특별조치법시행규칙 [별표]\n\n검정에필요한시공품량(최소량)\n\n┏━━━━━━┯━━━┯━━┯━┯━━┯━━┯━━━┯━━┯━━┯━━┯━━┯━━┯━━┯━━┯━━┯━━┯━━┯━┯━━┯━━┯━━┯━━┯━━┓\n┃시험항목    │①    │②  │③│④  │⑤  │⑥    │⑦  │⑧  │⑨  │⑩  │⑪  │⑫  │⑬  │⑭  │⑮  │?  │?│?  │?  │?  │    │    ┃\n┃            │      │    │  │    │    │      │    │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┃            │내용  │비중│PH│붕  │중량│확인  │정량│발열│용출│건조│강열│강열│알코│메탄│비소│중  │납│증발│알코│에텔│수성│멸군┃\n┃제제류      │량    │    │  │해도│편차│시험  │    │성  │알카│감량│감량│잔분│올수│올및│    │금속│  │잔류│올엑│엑기│엑기│도  ┃\n┃            │(포장 │    │  │    │    │      │    │물질│리  │    │    │    │    │아세│    │    │  │물  │기스│스  │스  │    ┃\n┃            │단위) │    │  │    │    │      │    │    │    │    │    │    │    │톤  │    │    │  │    │    │    │    │    ┃\n┠──────┼───┼──┼─┼──┼──┼───┼──┼──┼──┼──┼──┼──┼──┼──┼──┼──┼─┼──┼──┼──┼──┼──┨\n┃원료약품    │9     │    │  │    │    │1g    │2g  │    │    │6g  │6g  │6g  │    │    │6g  │6g  │6g│    │    │    │    │    ┃\n┠──────┼───┼──┼─┼──┼──┼───┼──┼──┼──┼──┼──┼──┼──┼──┼──┼──┼─┼──┼──┼──┼──┼──┨\n┃일반제제    │      │    │  │    │    │      │    │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┠──────┼───┼──┼─┼──┼──┼───┼──┼──┼──┼──┼──┼──┼──┼──┼──┼──┼─┼──┼──┼──┼──┼──┨\n┃과립제      │9     │    │  │18개│    │2g    │10g │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┠──────┼───┼──┼─┼──┼──┼───┼──┼──┼──┼──┼──┼──┼──┼──┼──┼──┼─┼──┼──┼──┼──┼──┨\n┃리모나아데제│9     │100 │50│    │    │10    │100 │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┃            │      │ml  │ml│    │    │ml    │ml  │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┠──────┼───┼──┼─┼──┼──┼───┼──┼──┼──┼──┼──┼──┼──┼──┼──┼──┼─┼──┼──┼──┼──┼──┨\n┃방향수제    │9     │100 │50│    │    │10    │100 │    │    │    │    │    │    │    │    │    │  │    │    │    │    │    ┃\n┃            │      │ml  │ml│    │    │ml    │ml  │    │    │    │    │    │    │    │    │    │  │ 