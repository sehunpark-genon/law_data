      {
        "article_no": "제6조",
        "article_title": "조약",
        "chapter": "",
        "content": "제6조(조약) 조약 공포문의 전문에는 국회의 동의 또는 국무회의의 심의를 거친 사실을 적고, 대통령이 서명한 후 대통령인을 찍고 그 공포일을 명기하여 국무총리와 관계 국무위원이 부서한다.",
        "enforcement_date": "20181016",
        "relations": [],
        "images": [],
        "provision_id": "law:법령등공포에관한법률#JO0006"
