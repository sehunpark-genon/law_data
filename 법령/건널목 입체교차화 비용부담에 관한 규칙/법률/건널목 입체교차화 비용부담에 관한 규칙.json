  "body": {
    "format": "articles",
    "article_count": 3,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 영은 건널목개량촉진법시행령 제8조의 규정에 의하여 건널목의 입체교차화에 따른 비용부담에 관하여 필요한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "19740610",
        "relations": [],
        "images": [],
        "provision_id": "law:건널목입체교차화비용부담에관한규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "적용범위",
        "chapter": "",
        "content": "제2조 (적용범위) 지방도ㆍ시도 및 군도의 건널목을 입체교차화할 경우의 도로관리청과 철도경영자 간의 비용부담은 이 영이 정하는 바에 의한다.",
        "enforcement_date": "19740610",
        "relations": [],
        "images": [],
        "provision_id": "law:건널목입체교차화비용부담에관한규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "비용부담의 기준",
        "chapter": "",
        "content": "제3조 (비용부담의 기준)\n①건널목의 입체교차화에 소요되는 구조물 설치비, 가선비 및 보상비 기타 입체교차화에 소요되는 일체의 비용은 도로관리청과 철도경영자가 그 전액의 5할씩을 부담한다.\n②제1항의 보상비중 기존 건널목의 폭이 확장되는 경우 그 확장되는 부분에서 발생하는 용지 및 당해용지에 설치된 지장물등에 대한 보상비는 제1항의 규정에 불구하고 도로관리청이 부담한다.",
        "enforcement_date": "19740610",
