      {
        "article_no": "제9조",
        "article_title": "선박명칭의 변경",
        "chapter": "",
        "content": "제9조 (선박명칭의 변경) 한국선박의 명칭을 변경하고자 할 때에는 해운항만청장의 허가를 받아야 한다. <개정 1975.12.31>",
        "enforcement_date": "19781205",
        "relations": [
          {
            "relation_type": "delegation",
            "delegation_type": "시행규칙",
            "target_category": "법령",
            "source_article_no": "제9조",
            "source_clause": "제9조제4항",
            "link_text": "해양수산부령",
            "line_text": "필요한 사항은 해양수산부령으로",
