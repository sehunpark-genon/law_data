          {
            "relation_type": "appendix_ref",
            "delegation_type": null,
            "target_category": "별지",
            "source_article_no": "제3조",
            "source_clause": "제3조제1항",
            "link_text": "별지 제1호",
            "line_text": "① 법 제26조제1항에 따라 산업융합지원센터(이하 \"센터\"라 한다)로 지정받으려는 자는 별지 제1호서식의 산업융합지원센터 지정신청서에 다음 각 호의 서류를 첨부하여 산업통상부장관에게 제출하여야 한다. <개정 2013.3.23, 2025.10.1>",
            "target_law_name": "산업융합 촉진법 시행규칙",
            "target_article_no": "별지1",
            "target_article_title": "산업융합지원센터 지정신청서",
            "appendix_no": "1",
