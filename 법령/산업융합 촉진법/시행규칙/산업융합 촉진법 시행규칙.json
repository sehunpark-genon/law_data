            "target_mst": "",
            "appendix_dangling": false,
            "target_url": "https://www.law.go.kr/LSW/flDownload.do?flSeq=156722637",
            "resolve_method": "text_parse",
            "source_provision_id": "law:산업융합촉진법시행규칙#JO0003",
            "reference_id": "law:산업융합촉진법시행규칙#BJ0001"
          },
          {
            "relation_type": "appendix_ref",
            "delegation_type": null,
            "target_category": "별지",
            "source_article_no": "제3조",
            "source_clause": "제3조제2항",
            "link_text": "별지 제2호",
            "line_text": "② 산업통상부장관은 법 제26조제1항에 따라 센터를 지정할 때에는 별지 제2호서식의 산업융합지원센터 지정서를 신청인에게 발급하여야 하며, 영 제31조제2항에 따라 관보 또는 인터넷 홈페이지에 공고하여야 한다. <개정 2013.3.23, 2025.10.1>",
