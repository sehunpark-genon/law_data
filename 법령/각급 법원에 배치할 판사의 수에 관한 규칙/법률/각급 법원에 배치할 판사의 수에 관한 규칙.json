      │35  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│수원지방법원    │         │1         │         │     │54      │     │       │124     │179 │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│수원가정법원    │         │1         │         │     │5       │     │       │10      │16  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│성남지원        │         │         │         │1     │14      │     │       │33      │48  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│여주지원        │         │         │         │1     │4       │     │       │9       │14  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│평택지원        │         │         │         │1     │8       │     │       │12      │21  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│안산지원        │         │         │         │1     │12      │     │       │29      │42  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│안양지원        │         │         │         │1     │9       │     │       │18      │28  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│춘천지방법원    │         │1         │         │     │15      │     │       │15      │31  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│강릉지원        │         │         │         │1     │9       │     │       │9       │19  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│원주지원        │         │         │         │1     │6       │     │       │7       │14  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│속초지원        │         │         │         │1     │1       │     │       │4       │6   │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│영월지원        │         │         │         │1     │1       │     │       │6       │8   │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│대전지방법원    │         │1         │         │     │46      │     │       │47      │94  │\n├────────┼─────┼─────┼─────┼───┼────┼───┼────┼────┼──┤\n│대전가정법원    │         │1         │       