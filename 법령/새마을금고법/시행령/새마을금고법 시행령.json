      {
        "article_no": "제24조",
        "article_title": "이자율",
        "chapter": "",
        "content": "제24조 (이자율) 금고 및 연합회의 예탁금ㆍ적금 및 대출금의 종목과 이자율의 최고한도는 내무부장관이 재무부장관과 합의하여 정한다.",
        "enforcement_date": "19830411",
        "relations": [],
        "images": [],
        "provision_id": "law:새마을금고법시행령#JO0024"
