    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "제1장 총칙",
        "content": "제1조 (목적) 이 규칙은 군사법원법 제4조의 규정에 의하여 군사법원의 내부규율과 사무처리에 관하여 필요한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "문서등의 수발",
        "chapter": "제2장 일반사무처리",
        "content": "제2조 (문서등의 수발) 수발문서와 물건은 이를 문서건명부에 기재하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "문서등의 배부",
        "chapter": "제2장 일반사무처리",
        "content": "제3조 (문서등의 배부)\n①문서건명부에 기재한 문서에 관하여는 적당한 곳에 접수연월일과 번호를 기입하고 물건에 관하여는 지편 기타 표찰을 부쳐 그 행정사무에 관한 것은 서기과장에게, 재판사무에 관한 것은 담임서기에게 교부하여야 한다.\n②제1항에 의하여 문서 또는 물건을 교부받은 자는 이를 지체없이 심판부장 또는 담임군판사에게 제출하여 결재를 얻어야 한다. 다만, 결재를 받을 필요가 없다고 인정되는 경우에는 그러하지 아니하다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "전화청취서",
        "chapter": "제2장 일반사무처리",
        "content": "제4조 (전화청취서) 전화로 조회하거나 그 회답 또는 보고를 받았을 경우에 중요한 사항에 관하여는 전화청취서를 작성하여 이를 문서건명부에 기재하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "금권, 우표등",
        "chapter": "제2장 일반사무처리",
        "content": "제5조 (금권, 우표등)\n①문서에 금권(金券), 우표 또는 인지 기타의 물건을 첨부한 것이 있을 때에는 문서난외와 문서건명부에 그 품목과 수량을 기입하여야 한다.\n②제1항의 첨부물을 제3조에 규정된 자에게 교부한 때에는 문서건명부 비고난에 수령인을 받아야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "문서등의 발송",
        "chapter": "제2장 일반사무처리",
        "content": "제6조 (문서등의 발송)\n①문서를 발송할 때에는 원안을 작성하여 행정사무에 관한 것은 심판부장의 결재를, 재판사무에 관한 것은 담임군판사의 결재를 받은 후 정서 교합하고 그 문서에 번호를 기입하여 발송하여야 한다.\n②물건을 발송할 때에는 그 물건에 관계문서번호를 기입한 지편 기타 표찰을 붙이고 발송문서의 난외에 물건첨부의 기호를 붙여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "원안의 편철",
        "chapter": "제2장 일반사무처리",
        "content": "제7조 (원안의 편철)\n①발송문서의 원안은 관계서류에 이를 편철하여야 한다.\n②원안이 없을 때에는 그 문서의 요지를 관계서류의 여백에, 관계서류가 없을 때에는 문서건명부에 기재하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "번역문 첨부",
        "chapter": "제2장 일반사무처리",
        "content": "제8조 (번역문 첨부) 국어를 해득하지 못하는 외국인에게 교부 또는 제시할 문서로서 필요하다고 인정하는 것에는 번역문을 붙여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0008"
      },
      {
        "article_no": "제9조",
        "article_title": "친전문서등",
        "chapter": "제2장 일반사무처리",
        "content": "제9조 (친전문서등) 친전문서 및 비(秘)에 속하는 문서는 지체없이 수신명의인에게 교부하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0009"
      },
      {
        "article_no": "제10조",
        "article_title": "문서등의 부외 반출",
        "chapter": "제2장 일반사무처리",
        "content": "제10조 (문서등의 부외 반출) 문서 또는 물건은 심판부장의 허가를 받지 아니하고는 이를 부외에 반출하지 못한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0010"
      },
      {
        "article_no": "제11조",
        "article_title": "사건기록등의 접수",
        "chapter": "제2장 일반사무처리",
        "content": "제11조 (사건기록등의 접수) 담임서기가 사건기록 기타 관계문서의 송부를 받았을 때는 그 종류에 따라 해당사건부에 기재한 후 이를 담임군판사에게 제출하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0011"
      },
      {
        "article_no": "제12조",
        "article_title": "기록의 편철방법",
        "chapter": "제2장 일반사무처리",
        "content": "제12조 (기록의 편철방법)\n①기록을 접수하거나 또는 작성한 때에는 표지와 목록을 붙여 이를 편철하며, 그 뒤에 접수 또는 작성한 것은 그 순서에 따라 이를 덧붙여 편철하고 기록의 장수가 많은 것은 분류하여 편철한다.\n②목록은 사건종국 후에 기재하고 매장 표면하단 중앙에 장수를 표시하여야 한다. 다만, 재판서와 확인서는 전체 장수에는 포함시키되, 그 장수의 기입은 하지 아니한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0012"
      },
      {
        "article_no": "제13조",
        "article_title": "열람과 등사",
        "chapter": "제2장 일반사무처리",
        "content": "제13조 (열람과 등사) 기록, 증거물 기타 서류의 열람 또는 등사는 일정한 장소에서 상당한 감시하에 이를 행하게 하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0013"
      },
      {
        "article_no": "제14조",
        "article_title": "압수물건의 처리",
        "chapter": "제2장 일반사무처리",
        "content": "제14조 (압수물건의 처리)\n①군사법원에서 압수한 물건에는 압수번호, 사건번호, 물건번호 및 피고인의 성명을 표시한 지편 기타 표찰을 붙여 지체없이 검찰부 압수물취급 주무자에게 교부하여야 한다.\n②동일 사건에 관하여 수사기관에 의하여 압수된 물건이 있을 경우에는 제1항의 압수번호는 수사기관의 압수번호와 일련번호로 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0014"
      },
      {
        "article_no": "제15조",
        "article_title": "변호인의 선임등 통지",
        "chapter": "제2장 일반사무처리",
        "content": "제15조 (변호인의 선임등 통지) 구속중인 피고인에 대하여 변호인의 선임, 취소 또는 사임이 있을 때에는 지체없이 교도소장에게 통지하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0015"
      },
      {
        "article_no": "제16조",
        "article_title": "기록의 구분",
        "chapter": "제3장 기록",
        "content": "제16조 (기록의 구분) 기록중 행정사무에 관한 것은 서무기록, 재판사무에 관한 것은 사건기록이라 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0016"
      },
      {
        "article_no": "제17조",
        "article_title": "서무기록의 종류",
        "chapter": "제3장 기록",
        "content": "제17조 (서무기록의 종류) 서무기록은 다음과 같이 분류한다.\n1.  군사법원조직에 관한 기록\n2.  감독사무에 관한 기록\n3.  예규에 관한 기록\n4.  통계에 관한 기록\n5.  회계에 관한 기록\n6.  잡사에 관한 기록\n7.  기밀에 관한 기록\n8.  기타 필요한 기록",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0017"
      },
      {
        "article_no": "제18조",
        "article_title": "사건기록",
        "chapter": "제3장 기록",
        "content": "제18조 (사건기록) 사건기록은 매건마다 별책으로 한다. 다만, 군사법원의 관할 또는 소송절차에 관하여 판결전에 한 재판사건, 구속취소, 보석 또는 구속집행정지의 신청, 형을 정하는 청구, 기피 또는 제척의 신청, 형의 집행유예취소의 청구, 형의 선고에 대한 의의(疑義)와 형의 집행에 대한 이의(異議)에 관한 기록은 본안기록에, 형사보상청구에 관한 기록은 무죄 또는 면소로 된 기록에 첨철한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0018"
      },
      {
        "article_no": "제19조",
        "article_title": "사건번호",
        "chapter": "제3장 기록",
        "content": "제19조 (사건번호)\n①사건기록에는 사건번호를 붙여야 한다.\n②사건번호는 서기연수의 10단위이하의 아라비아숫자, 사건별 부호문자와 진행번호인 아라비아숫자로 표시한다,\n③사건별 부호는 별표와 같다. 다만, 모든 재심사건은 재심대상재판서의 사건부호 앞에 재를 삽입한다.\n④사건에 관하여 최초에 붙인 사건번호와 사건명은 그 사건이 종국에 이르기까지 이를 사용한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0019"
      },
      {
        "article_no": "제20조",
        "article_title": "환, 이송사건",
        "chapter": "제3장 기록",
        "content": "제20조 (환, 이송사건) 대법원, 상급군사법원 또는 동등군사법원으로부터 환, 이송된 사건은 사건번호를 붙여서 이를 사건부에 등록하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0020"
      },
      {
        "article_no": "제21조",
        "article_title": "부책의 종류",
        "chapter": "제4장 부책",
        "content": "제21조 (부책의 종류)\n①심판부에는 다음의 부책을 비치하여야 한다.\n1.  문서건명부\n2.  공판사건부\n3.  신청사건부\n4.  항고사건부\n5.  재심사건부\n6.  재판결과통지부\n7.  확인결과통지부\n8.  상소결과부\n9.  열람 및 등사부\n10.  기일부\n11.  기일통지부\n12.  재감인소환부\n13.  구속ㆍ압수ㆍ수색영장원부\n14.  구속ㆍ압수ㆍ수색영장동의부\n15.  부책보존부\n16.  사무기록보존부\n17.  보존기록부책출입부\n18.  기타 필요한 부책\n②부책은 매년 이를 갱신하여야 한다. 다만, 필요에 의하여 누년 계속 사용할 수 있다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0021"
      },
      {
        "article_no": "제22조",
        "article_title": "기록과 부책의 보존",
        "chapter": "제5장 보존",
        "content": "제22조 (기록과 부책의 보존) 기록과 부책의 종류별 보존기간은 다음과 같다.\n1.  영구보존\n가.  각종사건부\n나.  군사법원조직에 관한 기록\n다.  부책보존부 및 서무기록보존부\n라.  예규에 관한 기록\n마.  기밀에 관한 기록\n2.  10년보존\n가.  판결과 확인서의 각 등본, 형법 제36조, 제39조제3항에 의하여 다시 형을 정하는 결정, 형의 집행유예취소의 결정 및 공소기각의 결정의 각 등본\n나.  통계에 관한 기록\n다.  감독사무에 관한 기록\n라.  회계에 관한 기록\n3.  3년보존\n가.  잡사에 관한 기록\n나.  구속ㆍ압수ㆍ수색영장원부\n다.  구속ㆍ압수ㆍ수색영장동의부\n라.  기일부\n마.  기일통지부\n바.  재감인소환부\n사.  재판결과통지부\n아.  이외의 각종 부책",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0022"
      },
      {
        "article_no": "제23조",
        "article_title": "기간의 기산",
        "chapter": "제5장 보존",
        "content": "제23조 (기간의 기산)\n①보존기간은 사건의 종국, 완결 또는 기재를 마친 다음해부터 기산한다.\n②보존기간을 달리한 관련서류는 그 기간의 긴 것에 따른다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0023"
      },
      {
        "article_no": "제24조",
        "article_title": "재판등본의 보존",
        "chapter": "제5장 보존",
        "content": "제24조 (재판등본의 보존) 제1심 또는 원심군사법원은 그 심급의 재판등본과 상소심의 재판등본을 같이 보존한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0024"
      },
      {
        "article_no": "제25조",
        "article_title": "보존부등록",
        "chapter": "제5장 보존",
        "content": "제25조 (보존부등록) 서무기록과 부책은 그 종류에 따라 구분하여 서무기록보존부 또는 부책보존부에 등록하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0025"
      },
      {
        "article_no": "제26조",
        "article_title": "출입부등록",
        "chapter": "제5장 보존",
        "content": "제26조 (출입부등록) 보존중인 기록과 부책을 부외에 교부 또는 송부한 때와 그 반환을 받은 때에는 보존기록부책출입부에 등록하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0026"
      },
      {
        "article_no": "제27조",
        "article_title": "서무기록의 편찬",
        "chapter": "제5장 보존",
        "content": "제27조 (서무기록의 편찬)\n①서무기록은 사건완결의 순서에 따라 이를 편찬하여야 한다.\n②각 사건에 속하는 문서의 순서는 그 경과순서에 의한다.\n③서무기록은 매년 편찬한다. 다만, 누년 계속 사용하는 것이 편리하다고 인정되는 것은 그러하지 아니하다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0027"
      },
      {
        "article_no": "제28조",
        "article_title": "보존종료연도표시",
        "chapter": "제5장 보존",
        "content": "제28조 (보존종료연도표시) 기록과 부책에는 그 표지에 보존종료연도를 주서하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0028"
      },
      {
        "article_no": "제29조",
        "article_title": "기록등의 보관",
        "chapter": "제5장 보존",
        "content": "제29조 (기록등의 보관) 기록과 부책은 일정한 장소에 보관하여야 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0029"
      },
      {
        "article_no": "제30조",
        "article_title": "기록등의 폐기",
        "chapter": "제5장 보존",
        "content": "제30조 (기록등의 폐기) 보존기간이 경과된 기록과 부책은 관할관의 인가를 받아 이를 폐기하여야 한다. 폐기는 소각을 원칙으로 한다.",
        "enforcement_date": "19890901",
        "relations": [],
        "images": [],
        "provision_id": "law:군사법원사무규칙#JO0030"
      }
    ]
