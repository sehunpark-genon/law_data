    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 법은 독립기념관(이하 \"紀念館\"이라 한다)을 설립하여 외침을 극복하고 민족의 자주와 독립을 지켜 온 우리 민족의 국난극복사와 국가발전사에 관한 자료를 수집ㆍ전시하게 함으로써 국민의 투철한 민족정신과 국가관을 정립하는데 이바지하게 함을 목적으로 한다.",
        "enforcement_date": "19860509",
        "relations": [],
        "images": [],
        "provision_id": "law:독립기념관법#JO0001"
      },
      {
