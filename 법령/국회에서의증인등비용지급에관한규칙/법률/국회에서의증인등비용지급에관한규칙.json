            "target_law_name": "국회에서의 증언ㆍ감정 등에 관한 법률",
            "target_article_no": "제11조",
            "target_article_title": "여비ㆍ수당의 지급",
            "target_mst": "276041",
            "target_url": "https://www.law.go.kr/법령/국회에서의 증언ㆍ감정 등에 관한 법률/제11조",
            "resolve_method": "rendered_link",
