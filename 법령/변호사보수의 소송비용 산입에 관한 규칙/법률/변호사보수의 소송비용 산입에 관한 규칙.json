  "body": {
    "format": "articles",
    "article_count": 6,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 규칙은 소송촉진등에관한특례법 제16조제1항에 의하여 소송비용에 산입할 변호사보수의 금액을 정함을 목적으로 한다.",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "적용범위",
        "chapter": "",
        "content": "제2조 (적용범위) 이 규칙은 민사소송법상 소송비용액의 확정결정 신청을 할 수 있는 사건에 적용한다.",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "산입할 보수의 기준",
        "chapter": "",
        "content": "제3조 (산입할 보수의 기준) 소송비용에 산입되는 변호사의 보수는 당사자가 보수계약에 의하여 지급한 또는 지급할 보수액의 범위내에서 각 심급단위로 소송물의 가액에 따라 별표의 기준에 의하여 산정한다.",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "소송물가액의 산정기준",
        "chapter": "",
        "content": "제4조 (소송물가액의 산정기준)\n①제3조의 소송물 가액의 산정에 있어서는 대법원의 소가산정에 관한 예규를 기준으로 한다. 다만, 비재산권상의 청구와 재산권상의 청구로서 소송물의 가액을 산정할 수 없는 것은 소송물의 가액을 500만원으로 본다.\n②청구취지를 변경한 경우에는 변경한 청구취지를 기준으로 한다.",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "보수의 감액",
        "chapter": "",
        "content": "제5조 (보수의 감액) 다음 각호의 경우에 소송비용에 산입할 변호사의 보수는 제3조의 기준에 의하여 산정한 금액의 2분의 1로 한다.\n1.  피고의 전부자백 또는 의제자백에 의한 판결의 경우\n2.  소송이 화해, 청구의 포기, 인낙 기타 재판에 의하지 아니하고 완결한 경우",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "재량 감액",
        "chapter": "",
        "content": "제6조 (재량 감액) 제3조 및 제5조의 금액 전부를 소송비용에 산입하는 것이 현저히 부당하다고 인정되는 경우에는 법원은 상당한 정도까지 감액산정할 수 있다.",
        "enforcement_date": "19810301",
        "relations": [],
        "images": [],
        "provision_id": "law:변호사보수의소송비용산입에관한규칙#JO0006"
      }
    ]
  },
