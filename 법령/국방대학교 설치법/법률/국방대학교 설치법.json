    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조(목적) 이 법은 국가안전보장에 관련되는 안보정책ㆍ국방관리 등에 관한 학술의 교육ㆍ연구ㆍ분석 및 발전을 도모하고, 국가안전보장에 관한 업무를 담당할 전문인력을 양성하기 위하여 국방대학교를 설치하고 그 운영에 관한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "20170622",
