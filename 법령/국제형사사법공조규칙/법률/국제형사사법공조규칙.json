            "target_article_title": "검사 등의 처분",
            "target_mst": "228083",
            "target_url": "https://www.law.go.kr/법령/국제형사사법 공조법/제17조",
            "resolve_method": "rendered_link",
            "source_provision_id": "law:국제형사사법공조규칙#JO0002",
            "reference_id": "law:국제형사사법공조법#JO0017"
          }
