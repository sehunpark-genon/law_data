      },
      {
        "article_no": "제13조",
        "article_title": "교육의 지도등",
        "chapter": "제3장 교육운영               제1절 통칙",
        "content": "제13조 (교육의 지도등) 교육원은 각급 법원의 자체 교육훈련계획의 수립과 교재편찬에 관하여 필요한 지도와 지원을 할 수 있다.",
        "enforcement_date": "19890519",
        "relations": [],
        "images": [],
