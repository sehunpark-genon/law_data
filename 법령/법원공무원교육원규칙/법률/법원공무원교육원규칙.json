  "body": {
    "format": "articles",
    "article_count": 6,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 법원조직법 제21조의 규정에 정한 법원공무원의 훈련양성을 위하여 대법원에 법원공무원 교육원을 둔다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "원장·부원장",
        "chapter": "",
        "content": "제2조 (원장ㆍ부원장)\n①법원공무원 교육원에 원장 1인ㆍ부원장 1인을 둔다.\n②원장은 대법원장의 지휘를 받아 원무를 장리하며 소속직원을 지휘 감독한다.\n③원장은 지방법원장급의 법관으로 보한다.\n④부원장은 원장을 보좌하며 원무를 처리하고 원장이 궐위되거나 유고시에는 그 권한을 대행한다.\n⑤부원장은 법원관리관으로 보한다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "교관·강사",
        "chapter": "",
        "content": "제3조 (교관ㆍ강사)\n①교육훈련을 담당하게 하기 위하여 교관 및 강사를 둔다.\n②교관은 법원부이사관 또는 법원서기관으로 보하고, 강사는 원장이 위촉한다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "사무국",
        "chapter": "",
        "content": "제4조 (사무국)\n①법원공무원 교육원에 사무국을 둔다.\n②사무국에 총무과ㆍ기획과ㆍ교무과ㆍ자료과를 두며 각과의 분장사무는 별표와 같다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "국장·과장",
        "chapter": "",
        "content": "제5조 (국장ㆍ과장)\n①국에는 국장, 과에는 과장을 둔다.\n②국장은 법원부이사관으로 보하고, 과장은 법원서기관으로 보한다.\n③국장과 과장은 상사의 명을 받아 국 또는 과의 사무를 장리하고 소속직원을 지휘 감독한다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "운영",
        "chapter": "",
        "content": "제6조 (운영) 법원공무원 교육원의 운영에 관한 사항은 대법원내규로 정한다.",
        "enforcement_date": "19790413",
        "relations": [],
        "images": [],
        "provision_id": "law:법원공무원교육원규칙#JO0006"
      }
    ]
  },
  "addenda": [
    {
      "promulgation_date": "19790413",
      "promulgation_no": "00682",
      "addendum_key": "1979041300682",
      "content": "부칙 <제682호,1979.4.13>\n제1조 (시행일) 이 규칙은 공포한 날로부터 시행한다.\n제2조 (경과규정) 대법원장은 이 규칙에 의한 법원공무원 교육원의 운영을 필요한 예산조치가 될 때까지 사법연수원장으로 하여금 대행하게 할 수 있다."
    }
  ],
