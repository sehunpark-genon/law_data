    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 법은 문화예술의 진흥을 위한 사업과 활동을 지원함으로써 우리나라의 전통적인 문화예술을 계승하고 새로운 문화를 창조하여 민족문화의 중흥에 기여하게 함을 목적으로 한다.",
        "enforcement_date": "19930306",
        "relations": [],
        "images": [],
        "provision_id": "law:문화예술진흥법#JO0001"
      },
      {
