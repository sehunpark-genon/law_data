        "content": "제2조 (방조제 실태조사) 영 제1조제2항의 규정에 의한 방조제실태조사는 별지 제7호서식에 의하여야 한다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "해제신청에 따른 서류",
        "chapter": "",
        "content": "제3조 (해제신청에 따른 서류) 영 제2조제2항의 규정에 의한 수익자부담금조서는 별지 제8호서식에 수지결산서는 별지 제9호서식에 의하여 작성하여야 한다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "고시사항의 게시",
        "chapter": "",
        "content": "제4조 (고시사항의 게시) 관리대행자가 영 제3조의 규정에 의하여 고시사항을 통지 받았을 때에는 그 통지사항을 당해방조제관리사업시행구역내에 5일이상 게시하여야 한다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "성명, 주소 변경신고",
        "chapter": "",
        "content": "제5조 (성명, 주소 변경신고) 원관리자 또는 관리대행자의 성명 또는 주소가 변경되었을 경우에는 지체없이 시ㆍ도지사를 거쳐 농수산부장관에게 보고하여야 한다. <개정 1985.11.26>",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "관리대행사무비",
        "chapter": "",
        "content": "제6조 (관리대행사무비)\n①영 제4조제2항의 규정에 의한 관리대행자의 방조제관리에 관한 사무비는 이에 소요되는 인건비ㆍ여비ㆍ수용비ㆍ분할측량 및 이전등기에 소요되는 비용과 일시차입금의 이자 및 잡지출의 범위내로 한다.\n②제1항의 사무비는 총공사비의 100분의 3이내로 하되 농수산부장관이 정한다. <개정 1985.11.26>",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "사업계획서",
        "chapter": "",
        "content": "제7조 (사업계획서) 영 제5조제1항의 규정에 의한 사업계획서의 내용은 별표와 같다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "측량, 설계 및 공사감독비",
        "chapter": "",
        "content": "제8조 (측량, 설계 및 공사감독비)\n①방조제관리사업에 관한 측량, 설계 및 공사감독비는 순공사비와 자재비의 합계액의 5퍼센트의 범위안에서 농수산부장관이 정한다.\n②제1항의 측량, 설계 및 공사감독은 농업진흥공사에 위탁할 수 있다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0008"
      },
      {
        "article_no": "제9조",
        "article_title": "수익자의 관리부담액의 산출",
        "chapter": "",
        "content": "제9조 (수익자의 관리부담액의 산출) 영 제6조제1항의 규정에 의한 수익자의 관리비 부담액의 산출은 별지 제6호서식에 의한다.",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0009"
      },
      {
        "article_no": "제10조",
        "article_title": "예산의 편성",
        "chapter": "",
        "content": "제10조 (예산의 편성) 영 제13조제1항의 규정에 의한 방조제관리에 관한 세입세출예산의 편성은 농수산부장관이 정하는 예산편성지침에 의한다. <개정 1985.11.26>",
        "enforcement_date": "19851126",
        "relations": [],
        "images": [],
        "provision_id": "law:방조제관리법시행규칙#JO0010"
      }
    ]
  },
