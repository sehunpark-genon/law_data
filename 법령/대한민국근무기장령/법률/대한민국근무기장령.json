  "body": {
    "format": "articles",
    "article_count": 8,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조(목적) 이 영은 대한민국에 근무하는 외국의 군인ㆍ군속에게 대한민국 근무기장(이하 \"기장\"이라 한다)을 수여함에 필요한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "수여대상",
        "chapter": "",
        "content": "제2조(수여대상)\n①기장은 대한민국에 주재하는 외국군(국제연합군을 포함한다)의 부대, 군사정전위원회, 각국 대사관 또는 기타 기관에서 6월이상 근무하고 이임하는 외국의 군인ㆍ군속(6월 미만 근무자로서 전ㆍ공상으로인하여 이임하는 자를 포함한다)에게 수여한다. 다만, 근무중 징계 또는 형사처벌을 받아 근무기간 만료전에 이임하는 자에게는 수여하지 아니한다.\n②대한민국에서 근무중 전사 또는 순직한 자에 대하여는 제1항의 규정에 불구하고 그 유족에게 기장을 수여할 수 있다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "제식",
        "chapter": "",
        "content": "제3조(제식) 기장의 제식은 별표와 같이 한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "증서",
        "chapter": "",
        "content": "제4조(증서) 기장을 받은 자에게는 기장과 함께 별지 서식의 대한민국근무 기장증을 수여한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "수여권자",
        "chapter": "",
        "content": "제5조(수여권자) 기장은 국방부장관이 수여한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "추서",
        "chapter": "",
        "content": "제6조(추서) 기장을 받은 자가 기장을 받기 전에 사망한 때에는 그 유족에게 이를 수여한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "패용",
        "chapter": "",
        "content": "제7조(패용) 기장은 본인만이 이를 패용할 수 있으며, 본인이 사망한 후에는 그 유족이 이를 보존한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "시행규칙",
        "chapter": "",
        "content": "제8조(시행규칙) 이 영의 시행에 관하여 필요한 사항은 국방부령으로 정한다.",
        "enforcement_date": "19740801",
        "relations": [],
        "images": [],
        "provision_id": "law:대한민국근무기장령#JO0008"
      }
    ]
  },
