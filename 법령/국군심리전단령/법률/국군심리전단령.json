  "body": {
    "format": "articles",
    "article_count": 6,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "설치",
        "chapter": "",
        "content": "제1조 (설치) 심리작전의 실시 및 지원을 위하여 국방부장관 소속하에 국군심리전단(이하 \"심리전단\"이라 한다)을 둔다.",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "임무",
        "chapter": "",
        "content": "제2조 (임무) 심리전단의 임무는 다음 각호와 같다.\n1.  적 및 가상적에 대한 심리작전 실시\n2.  수복 및 점령지역과 취약지역에 대한 선무심리전 지원\n3.  전술작전부대에 대한 선전물 제작 지원",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "단장",
        "chapter": "",
        "content": "제3조 (단장) ⓛ심리전단에 단장을 둔다.\n②단장은 영관급장교로 보한다.",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "단장의 직무",
        "chapter": "",
        "content": "제4조 (단장의 직무) 단장은 합동참모의장의 명을 받아 심리전단업무를 통할하고, 심리전단에 예속 또는 배속된 부대를 지휘ㆍ감독한다.",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "부서와 부대의 설치",
        "chapter": "",
        "content": "제5조 (부서와 부대의 설치)\n①심리전단에 필요한 참모부서와 부대를 둔다.\n②제1항의 참모부서의 설치와 업무분장에 관한 사항은 합동참모의장이, 부대의 설치ㆍ임무 및 조직에 관한 사항은 국방부장관이 정한다.",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "정원",
        "chapter": "",
        "content": "제6조 (정원) 심리전단에 두는 군인 및 군무원의 정원은 국방부장관이 정한다.",
        "enforcement_date": "19901001",
        "relations": [],
        "images": [],
        "provision_id": "law:국군심리전단령#JO0006"
      }
    ]
  },
